{
  "name": "gestao-financeira-monorepo",
  "private": true,
  "version": "0.2.0",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "node ./scripts/dev-orchestrator.js",
    "kill-ports": "node ./scripts/kill-ports.js",
    "install:all": "npm install --workspaces",
    "lint": "echo \"No root lint configured\"",
    "build": "npm run build --workspace backend && npm run build --workspace frontend",
    "test": "npm --workspace backend run test && npm --workspace frontend run test",
    "e2e": "npm run build && playwright test",
    "e2e:install": "playwright install chromium --with-deps",
    "crawl:prod": "node scripts/prod-crawl.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "concurrently": "^8.2.0",
    "mongoose": "^7.0.0",
    "puppeteer": "^25.2.1"
  }
}
