{
  "name": "gestao-financeira-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "frontend",
    "backend",
    "UI"
  ],
  "scripts": {
    "dev": "node ./scripts/dev-orchestrator.js",
    "kill-ports": "node ./scripts/kill-ports.js",
    "install:all": "npm install --workspaces",
    "lint": "echo \"No root lint configured\"",
    "test": "npm --workspace backend run test && npm --workspace frontend run test"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "mongoose": "^7.0.0"
  },
  "dependencies": {
    "puppeteer": "^25.2.1"
  }
}
