# Copie para .env na raiz do projeto no servidor:
#   cp deploy/env.production.example .env

# Imagens (preenchidas automaticamente pelo GitHub Actions)
BACKEND_IMAGE=ghcr.io/SEU_USUARIO/gestao-financeira-backend:latest
WEB_IMAGE=ghcr.io/SEU_USUARIO/gestao-financeira-web:latest

# MongoDB
MONGO_URI=mongodb://mongo:27017/finance

# Backend
PORT=4000
NODE_ENV=production
COOKIE_SAME_SITE=lax

JWT_ACCESS_SECRET=troque_por_um_segredo_forte
JWT_REFRESH_SECRET=troque_por_outro_segredo_forte
JWT_ACCESS_EXP=15m
JWT_REFRESH_EXP=7d
SEED_ADMIN_PASSWORD=troque_antes_do_primeiro_seed

# Exportação fluxo de caixa
FLUXO_CAIXA_SALDO_INICIAL=0
FLUXO_CAIXA_ASAAS_SALDO_INICIAL=0

FLUXO_CAIXA_EMPRESA_NOME=
FLUXO_CAIXA_EMPRESA_CNPJ=
FLUXO_CAIXA_NUBANK_CONTA=

FLUXO_CAIXA_ASAAS_EMPRESA_NOME=
FLUXO_CAIXA_ASAAS_EMPRESA_CNPJ=
FLUXO_CAIXA_ASAAS_BANCO=
FLUXO_CAIXA_ASAAS_CONTA=
