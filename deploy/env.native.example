# Copie para /opt/gestao-financeira/.env
#   cp deploy/env.native.example .env

PORT=4000
MONGO_URI=mongodb://127.0.0.1:27017/finance
NODE_ENV=production
COOKIE_SAME_SITE=lax
APP_DOMAIN=financeiro.seumovimento.com.br
# URL pública do app (convites, Stripe). Se vazio, deriva de APP_DOMAIN com https.
FRONTEND_URL=https://financeiro.seumovimento.com.br

JWT_ACCESS_SECRET=troque_por_um_segredo_forte
JWT_REFRESH_SECRET=troque_por_outro_segredo_forte
JWT_ACCESS_EXP=15m
JWT_REFRESH_EXP=7d
SEED_ADMIN_PASSWORD=troque_antes_do_primeiro_seed

FLUXO_CAIXA_SALDO_INICIAL=0
FLUXO_CAIXA_ASAAS_SALDO_INICIAL=0

FLUXO_CAIXA_EMPRESA_NOME=
FLUXO_CAIXA_EMPRESA_CNPJ=
FLUXO_CAIXA_NUBANK_CONTA=

FLUXO_CAIXA_ASAAS_EMPRESA_NOME=
FLUXO_CAIXA_ASAAS_EMPRESA_CNPJ=
FLUXO_CAIXA_ASAAS_BANCO=
FLUXO_CAIXA_ASAAS_CONTA=

# Stripe (opcional — billing self-service)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=

# Push notifications (opcional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@finance.local

# Import Intelligence (opcional — none = só heurística, sem API paga)
IMPORT_AI_PROVIDER=none
IMPORT_AI_ENABLED=true
IMPORT_AI_MIN_CONFIDENCE=0.85
IMPORT_AI_DAILY_LIMIT=50
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL_ANALYSIS=gemini-2.0-flash
GEMINI_MODEL_COMPLEX=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Integrações — Honest (worker interno + endpoint para cron externo)
# Worker roda no processo do backend; cron opcional: POST /api/integrations/worker/run
# Header: x-integrations-cron-secret: <INTEGRATIONS_CRON_SECRET>
INTEGRATIONS_WORKER_ENABLED=true
INTEGRATIONS_WORKER_INTERVAL_MS=300000
INTEGRATIONS_CRON_SECRET=troque_por_segredo_integracoes
HONEST_REQUEST_TIMEOUT_MS=45000
