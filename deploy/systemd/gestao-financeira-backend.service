[Unit]
Description=Gestao Financeira API (NestJS)
After=network.target mongod.service
Wants=mongod.service

[Service]
Type=simple
User=opc
Group=opc
WorkingDirectory=/opt/gestao-financeira/backend
EnvironmentFile=/opt/gestao-financeira/.env
Environment=NODE_ENV=production
ExecStart=/usr/bin/node dist/main.js
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
