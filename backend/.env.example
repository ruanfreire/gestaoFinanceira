PORT=4000
MONGO_URI=mongodb://localhost:27017/finance
JWT_ACCESS_SECRET=replace_with_strong_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
JWT_ACCESS_EXP=15m
JWT_REFRESH_EXP=7d
SEED_ADMIN_PASSWORD=123456
SEED_SUPERADMIN_EMAIL=admin@fecho.local
SEED_SUPERADMIN_PASSWORD=fechoadmin@2026
# Kill switch global — desliga módulo para todos os tenants
# MODULE_KILL_SWITCH_DOCUMENT_CORE=true
# MODULE_KILL_SWITCH_LOGISTICS_FRETE=true
# SEED_RESET_PASSWORD=false
SEED_RESET_PASSWORD=false

# Exportação fluxo de caixa
# Saldo âncora apenas se não houver extrato anterior (primeira importação)
FLUXO_CAIXA_SALDO_INICIAL=0
FLUXO_CAIXA_ASAAS_SALDO_INICIAL=0

# Nubank
FLUXO_CAIXA_EMPRESA_NOME=ANA LUISA RICCI BARDI CALADO NECA
FLUXO_CAIXA_EMPRESA_CNPJ=39.803.761/0001-17
FLUXO_CAIXA_NUBANK_CONTA=

# Asaas
FLUXO_CAIXA_ASAAS_EMPRESA_NOME=MOVIMENTO ORGANIZACIONAL E HUMANO // ANA LUISA RICCI BARDI CALADO NECA 00356359913
FLUXO_CAIXA_ASAAS_EMPRESA_CNPJ=39.803.761/0001-17
FLUXO_CAIXA_ASAAS_BANCO=ASAAS Gestão Finance
# Stripe (Fase 2B)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=
# URL pública do app (convites, Stripe). Ajuste o domínio.
FRONTEND_URL=http://localhost:5174

# Resend — e-mails transacionais (convites, cadastro, aprovação)
RESEND_API_KEY=
RESEND_FROM=Fecho <onboarding@resend.dev>
# MAIL_ENABLED=false

# Import Intelligence — provedor de IA
# none | groq | ollama | gemini
IMPORT_AI_PROVIDER=none

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

GEMINI_API_KEY=
GEMINI_MODEL_ANALYSIS=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
IMPORT_AI_ENABLED=true
IMPORT_AI_MIN_CONFIDENCE=0.85
IMPORT_AI_DAILY_LIMIT=50
GEMINI_MODEL_COMPLEX=gemini-2.0-flash

# Integrações (Honest) — dev local
INTEGRATIONS_WORKER_ENABLED=true
INTEGRATIONS_WORKER_INTERVAL_MS=60000
INTEGRATIONS_CRON_SECRET=change-me-in-production
HONEST_REQUEST_TIMEOUT_MS=30000
HONEST_AUTH_BASE_URL=https://auth.honest.com.br
HONEST_KEYCLOAK_REALM=cliente
HONEST_KEYCLOAK_CLIENT_ID=back-front
# HONEST_KEYCLOAK_CLIENT_SECRET=
HONEST_OAUTH_REDIRECT_URI=https://honest.com.br/oauth2/callback
HONEST_APP_BASE_URL=https://honest.com.br
HONEST_API_BASE_URL=https://honest.com.br
API_PUBLIC_URL=http://localhost:4000/api
TEST_LOGIN=
TEST_SENHA=
HONEST_CLIENT_ENTRY_PATH=/u/acesso
# Login via navegador headless (Playwright). Em Linux/prod usa @sparticuz/chromium (sem dnf).
HONEST_BROWSER_LOGIN=true
# HONEST_BROWSER_BUNDLED=false  # força Playwright cache (exige libs do sistema)

