{
  "name": "gestao-financeira-backend",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child --rs src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "seed": "ts-node -r tsconfig-paths/register src/common/seeder.ts",
    "seed:prod": "node dist/common/seeder.js",
    "seed:ruan": "ts-node -r tsconfig-paths/register src/common/seed-ruan-data.ts",
    "seed:ruan:prod": "node dist/common/seed-ruan-data.js",
    "migrate:tenant": "ts-node -r tsconfig-paths/register src/common/migrate-default-tenant.ts",
    "reset-db": "ts-node -r tsconfig-paths/register src/common/reset-database.ts",
    "purge-notas-nao-pagas": "ts-node -r tsconfig-paths/register src/common/purge-notas-nao-pagas.ts",
    "push:replay": "ts-node -r tsconfig-paths/register src/common/replay-push-notifications.ts",
    "push:replay:prod": "node dist/common/replay-push-notifications.js",
    "db:diagnose": "node scripts/diagnose-db.mjs",
    "db:diagnose:prod": "node scripts/diagnose-db.mjs",
    "db:repair-notas": "node scripts/repair-notas-tenant.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:honest": "ts-node scripts/test-honest-login.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/mongoose": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^5.2.0",
    "argon2": "^0.30.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.0",
    "cookie-parser": "^1.4.6",
    "exceljs": "^4.4.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.0.0",
    "pino": "^8.11.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "stripe": "^22.3.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.7.2",
    "vitest": "^3.2.6"
  },
  "optionalDependencies": {
    "playwright": "^1.61.1"
  }
}
